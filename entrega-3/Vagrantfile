# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # Usaremos Ubuntu 20.04 (Focal Fossa) como base, es estable y compatible con OpenMPI
  config.vm.box = "ubuntu/focal64"
  
  # === Configuración del Master ===
  config.vm.define "master" do |master|
    master.vm.hostname = "master"
    master.vm.network "private_network", ip: "192.168.56.10"
    
    # La interfaz NAT (para internet) es creada por defecto por Vagrant en la primera interfaz.
    
    master.vm.provider "virtualbox" do |vb|
      vb.name = "SD_HPC_Master"
      vb.memory = "1024"
      vb.cpus = 1
      # Nota: Vagrant por defecto no redimensiona el disco principal fácilmente sin plugins extra.
      # Usaremos el disco por defecto de la box que suele ser suficiente (10GB-40GB)
      # o si tienes el plugin vagrant-disksize puedes usar:
      # master.disksize.size = "50GB" 
      # Por simplicidad y evitar errores si el usuario no tiene plugins, no redimensionamos
      # el disco primario aquí, pero la capacidad base será suficiente para compilar en C.
    end

    # Sincronizamos las carpetas de aprovisionamiento
    master.vm.provision "file", source: "provision/hosts", destination: "/tmp/hosts"
    master.vm.provision "shell", path: "provision/master.sh"
  end

  # === Configuración del Nodo 0 ===
  config.vm.define "nodo-0" do |nodo0|
    nodo0.vm.hostname = "nodo-0"
    nodo0.vm.network "private_network", ip: "192.168.56.11"
    
    nodo0.vm.provider "virtualbox" do |vb|
      vb.name = "SD_HPC_Nodo_0"
      vb.memory = "1024"
      vb.cpus = 1
    end

    nodo0.vm.provision "file", source: "provision/hosts", destination: "/tmp/hosts"
    nodo0.vm.provision "shell", path: "provision/nodo.sh"
  end

  # === Configuración del Nodo 1 ===
  config.vm.define "nodo-1" do |nodo1|
    nodo1.vm.hostname = "nodo-1"
    nodo1.vm.network "private_network", ip: "192.168.56.12"
    
    nodo1.vm.provider "virtualbox" do |vb|
      vb.name = "SD_HPC_Nodo_1"
      vb.memory = "1024"
      vb.cpus = 1
    end

    nodo1.vm.provision "file", source: "provision/hosts", destination: "/tmp/hosts"
    nodo1.vm.provision "shell", path: "provision/nodo.sh"
  end
end
