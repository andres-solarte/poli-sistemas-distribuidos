Vagrant.configure("2") do |config|
  SERVER_IP = "192.168.56.10"
  CLIENT_IP = "192.168.56.11"

  # Soporte multi-arquitectura:
  # - En hosts ARM64 usamos un box ARM64 compatible con VirtualBox.
  # - En hosts AMD64 usamos el box estándar x86_64.
  host_arch = (ENV["VAGRANT_HOST_ARCH"] || `uname -m`).strip
  if host_arch == "arm64" || host_arch == "aarch64"
    config.vm.box = "cloudicio/ubuntu-server"
    config.vm.box_version = "24.04.1"
  else
    config.vm.box = "ubuntu/jammy64"
  end

  # Evita prompts durante provisioning
  config.vm.boot_timeout = 300

  config.vm.define "nfs-server" do |server|
    server.vm.hostname = "nfs-server"
    server.vm.network "private_network", ip: SERVER_IP

    server.vm.provider "virtualbox" do |vb|
      vb.name = "nfs-server"
      vb.cpus = 1
      vb.memory = 2048
    end

    # Disco principal en VirtualBox
    server.vm.disk :disk, size: "50GB", primary: true

    server.vm.provision "shell", path: "provisioning/common.sh"
    server.vm.provision "shell", path: "provisioning/nfs_server.sh", args: [CLIENT_IP]
  end

  config.vm.define "nfs-client" do |client|
    client.vm.hostname = "nfs-client"
    client.vm.network "private_network", ip: CLIENT_IP

    client.vm.provider "virtualbox" do |vb|
      vb.name = "nfs-client"
      vb.cpus = 1
      vb.memory = 2048
    end

    client.vm.disk :disk, size: "50GB", primary: true

    client.vm.provision "shell", path: "provisioning/common.sh"
    client.vm.provision "shell", path: "provisioning/nfs_client.sh", args: [SERVER_IP]
  end
end
